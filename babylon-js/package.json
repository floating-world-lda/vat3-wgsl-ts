{
  "description": "Houdini Vertex Animation Texture classes for Babylon.js",
  "devDependencies": {
    "@babylonjs/core": "^8.35.0",
    "@babylonjs/loaders": "^8.35.0",
    "@types/node": "^22.9.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "name": "@floatingworld/vat3-babylonjs",
  "peerDependencies": {
    "@babylonjs/core": "^8.35.0",
    "@babylonjs/loaders": "^8.35.0"
  },
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf dist",
    "deploy": "./bin/aws_deploy_api.sh",
    "release:patch": "./bin/git_release_version.sh patch",
    "release:minor": "./bin/git_release_version.sh minor",
    "release:major": "./bin/git_release_version.sh major",
    "release": "npm run typecheck && npm run build && npm run deploy",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": [
    "**/*.wgsl"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "0.1.5"
}
